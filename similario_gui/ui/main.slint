import { Button, ProgressIndicator, ListView, Palette } from "std-widgets.slint";

import { Themes, Settings } from "colors.slint";
import { FileRow, GroupKind, QualityTier } from "types.slint";
import { FileRowItem } from "file_row.slint";
import { SettingsPanel } from "settings_panel.slint";
import { Toolbar } from "toolbar.slint";
import { DeletePopup, TrashPopup } from "popups.slint";

export { Themes, Settings, FileRow, GroupKind, QualityTier }

export component MainWindow inherits Window {
    title: "Similario - similar videos";
    min-width: 900px;
    min-height: 600px;
    preferred-width: 1200px;
    preferred-height: 800px;
    background: Themes.current.window-bg;

    in-out property <[FileRow]> rows: [];
    in property <float> scan-progress: 0.0;
    in property <string> status-text: "Ready";
    in property <bool> scanning: false;

    // Compare config
    in-out property <float> cfg-tolerance: 0.15;
    in-out property <float> cfg-duration-tolerance-pct: 20;
    in-out property <float> cfg-min-matching-windows: 0.6;
    in-out property <float> cfg-subclip-min-match: 0.5;
    // Signature config
    in-out property <int> cfg-window-count: 5;
    in-out property <int> cfg-skip-secs: 15;
    in-out property <bool> cfg-cropdetect: true;
    // Audio config
    in-out property <bool> cfg-audio-fingerprint: false;
    in-out property <float> cfg-audio-max-difference: 3.0;
    in-out property <float> cfg-audio-min-segment-duration: 5.0;

    callback scan-clicked(string);
    callback stop-clicked();
    callback stop-and-compare-clicked();
    callback delete-selected();
    callback trash-selected();
    callback request-delete();
    callback request-trash();
    callback select-all(bool);
    callback row-double-clicked(int);
    callback check-toggled(int, bool);

    in property <string> delete-confirmation-text: "";
    in property <string> trash-confirmation-text: "";

    in-out property <string> dir-path: "";
    property <int> selected-row: -1;
    property <bool> settings-visible: false;

    init => {
        Palette.color-scheme = Settings.dark-theme ? ColorScheme.dark : ColorScheme.light;
    }
    changed dark-theme-flag => {
        Palette.color-scheme = Settings.dark-theme ? ColorScheme.dark : ColorScheme.light;
    }
    property <bool> dark-theme-flag: Settings.dark-theme;

    VerticalLayout {
        Toolbar {
            scanning: root.scanning;
            settings-visible: root.settings-visible;
            dir-path <=> root.dir-path;
            scan-clicked(d) => { root.scan-clicked(d); }
            stop-clicked => { root.stop-clicked(); }
            stop-and-compare-clicked => { root.stop-and-compare-clicked(); }
            settings-toggled => { root.settings-visible = !root.settings-visible; }
        }

        if root.settings-visible : SettingsPanel {
            cfg-tolerance <=> root.cfg-tolerance;
            cfg-duration-tolerance-pct <=> root.cfg-duration-tolerance-pct;
            cfg-min-matching-windows <=> root.cfg-min-matching-windows;
            cfg-subclip-min-match <=> root.cfg-subclip-min-match;
            cfg-window-count <=> root.cfg-window-count;
            cfg-skip-secs <=> root.cfg-skip-secs;
            cfg-cropdetect <=> root.cfg-cropdetect;
            cfg-audio-fingerprint <=> root.cfg-audio-fingerprint;
            cfg-audio-max-difference <=> root.cfg-audio-max-difference;
            cfg-audio-min-segment-duration <=> root.cfg-audio-min-segment-duration;
        }

        Rectangle {
            height: 28px;
            background: Themes.current.progress-bg;

            HorizontalLayout {
                padding-left: 8px;
                padding-right: 8px;
                spacing: 8px;

                ProgressIndicator {
                    horizontal-stretch: 1;
                    progress: root.scan-progress;
                    indeterminate: root.scanning && root.scan-progress == 0.0;
                }

                Text {
                    text: root.status-text;
                    color: Themes.current.text-secondary;
                    font-size: 11px;
                    vertical-alignment: center;
                }
            }
        }

        Rectangle {
            height: 24px;
            background: Themes.current.column-header-bg;

            HorizontalLayout {
                padding-left: 144px;
                padding-right: 8px;
                spacing: 12px;

                Text { text: "Name"; color: Themes.current.text-muted; font-size: 11px; font-weight: 600; vertical-alignment: center; horizontal-stretch: 1; }
                Text { text: "Size"; color: Themes.current.text-muted; font-size: 11px; font-weight: 600; vertical-alignment: center; width: 70px; horizontal-alignment: right; }
                Text { text: "Duration"; color: Themes.current.text-muted; font-size: 11px; font-weight: 600; vertical-alignment: center; width: 60px; horizontal-alignment: right; }
                Text { text: "FPS"; color: Themes.current.text-muted; font-size: 11px; font-weight: 600; vertical-alignment: center; width: 45px; horizontal-alignment: right; }
            }
        }

        FocusScope {
            vertical-stretch: 1;
            key-pressed(event) => {
                if event.text == " "
                    && root.selected-row >= 0
                    && !root.rows[root.selected-row].is-header
                {
                    root.check-toggled(root.selected-row, !root.rows[root.selected-row].checked);
                    accept
                } else {
                    reject
                }
            }

            ListView {
                width: 100%;
                height: 100%;

                for item[idx] in root.rows : FileRowItem {
                    data: item;
                    selected: root.selected-row == idx;
                    item-clicked => {
                        root.selected-row = idx;
                        if !item.is-header {
                            root.check-toggled(idx, !item.checked);
                        }
                    }
                    item-double-clicked => { root.row-double-clicked(idx); }
                    check-toggled(checked) => { root.check-toggled(idx, checked); }
                }
            }
        }

        Rectangle {
            height: 44px;
            background: Themes.current.toolbar-bg;

            HorizontalLayout {
                padding: 8px;
                spacing: 8px;

                Button {
                    text: "Select all except best";
                    clicked => { root.select-all(true); }
                }
                Button {
                    text: "Deselect all";
                    clicked => { root.select-all(false); }
                }
                Rectangle { horizontal-stretch: 1; }
                Button {
                    text: "Trash selected";
                    enabled: !root.scanning;
                    clicked => { root.request-trash(); }
                }
                Button {
                    text: "Delete selected";
                    enabled: !root.scanning;
                    clicked => { root.request-delete(); }
                }
            }
        }
    }

    delete-popup := DeletePopup {
        body-text: root.delete-confirmation-text;
        delete-confirmed => { root.delete-selected(); }
    }

    trash-popup := TrashPopup {
        body-text: root.trash-confirmation-text;
        trash-confirmed => { root.trash-selected(); }
    }

    public function show-delete-popup() { delete-popup.show-popup(); }
    public function show-trash-popup() { trash-popup.show-popup(); }
}
