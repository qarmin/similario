import { CheckBox } from "std-widgets.slint";
import { Themes } from "colors.slint";
import { FileRow, GroupKind, QualityTier } from "types.slint";

export component FileRowItem inherits Rectangle {
    pure function group-color(kind: GroupKind) -> color {
        if kind == GroupKind.identical { return Themes.current.group-identical; }
        if kind == GroupKind.same-content { return Themes.current.group-same-content; }
        if kind == GroupKind.sub-clip { return Themes.current.group-sub-clip; }
        return Themes.current.group-similar;
    }

    pure function group-label(kind: GroupKind) -> string {
        if kind == GroupKind.identical { return "IDENTICAL"; }
        if kind == GroupKind.same-content { return "SAME CONTENT"; }
        if kind == GroupKind.sub-clip { return "SUB-CLIP"; }
        return "SIMILAR";
    }

    pure function quality-stripe(t: QualityTier) -> color {
        if t == QualityTier.best { return Themes.current.quality-best; }
        if t == QualityTier.worse { return Themes.current.quality-worse; }
        return #00000000;
    }

    pure function quality-text(t: QualityTier, default-color: color) -> color {
        if t == QualityTier.best { return Themes.current.quality-best-text; }
        if t == QualityTier.worse { return Themes.current.quality-worse-text; }
        return default-color;
    }

    in property <FileRow> data;
    in property <bool> selected;
    callback item-clicked();
    callback item-double-clicked();
    callback check-toggled(bool);

    height: data.is-header ? 32px : 72px;
    background: data.is-header
        ? Themes.current.row-header-bg
        : (selected
            ? Themes.current.row-selected-bg
            : (touch.has-hover ? Themes.current.row-hover-bg : Themes.current.row-bg));

    touch := TouchArea {
        clicked => { root.item-clicked(); }
        double-clicked => { root.item-double-clicked(); }
    }

    if data.is-header : HorizontalLayout {
        padding: 8px;
        spacing: 8px;

        Rectangle {
            width: 4px;
            background: group-color(data.group-kind);
            border-radius: 2px;
        }

        Text {
            text: group-label(data.group-kind);
            color: Themes.current.text-strong;
            font-size: 12px;
            font-weight: 700;
            vertical-alignment: center;
        }
        Rectangle { horizontal-stretch: 1; }
        Text {
            text: data.name;
            color: Themes.current.text-secondary;
            font-size: 11px;
            vertical-alignment: center;
        }
    }

    if !data.is-header : HorizontalLayout {
        padding: 4px;
        spacing: 6px;

        // Quality tier indicator stripe on the very left
        Rectangle {
            width: 4px;
            background: quality-stripe(data.quality-tier);
            border-radius: 2px;
        }

        CheckBox {
            width: 20px;
            checked: data.checked;
            toggled => { root.check-toggled(self.checked); }
        }

        Rectangle {
            width: 112px;
            height: 63px;
            background: Themes.current.thumbnail-bg;
            border-radius: 3px;
            clip: true;

            Image {
                source: data.thumbnail;
                width: 112px;
                height: 63px;
                image-fit: contain;
            }
        }

        VerticalLayout {
            horizontal-stretch: 1;
            spacing: 2px;

            HorizontalLayout {
                spacing: 12px;
                Text {
                    text: data.name;
                    color: Themes.current.text-primary;
                    font-size: 12px;
                    font-weight: 600;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                Text { text: data.size; color: Themes.current.text-secondary; font-size: 11px; width: 70px; horizontal-alignment: right; }
                Text { text: data.duration; color: Themes.current.text-secondary; font-size: 11px; width: 60px; horizontal-alignment: right; }
                Text { text: data.fps; color: Themes.current.text-secondary; font-size: 11px; width: 45px; horizontal-alignment: right; }
            }
            HorizontalLayout {
                spacing: 12px;
                Text {
                    text: data.path;
                    color: Themes.current.text-muted;
                    font-size: 10px;
                    horizontal-stretch: 1;
                    overflow: elide;
                }
                Text {
                    text: data.dimensions;
                    color: quality-text(data.quality-tier, Themes.current.text-secondary);
                    font-size: 11px;
                    font-weight: data.quality-tier == QualityTier.best ? 700 : 400;
                    width: 70px;
                    horizontal-alignment: right;
                }
                Text {
                    text: data.bitrate;
                    color: quality-text(data.quality-tier, Themes.current.text-secondary);
                    font-size: 11px;
                    width: 60px;
                    horizontal-alignment: right;
                }
                Text {
                    text: data.codec;
                    color: quality-text(data.quality-tier, Themes.current.text-secondary);
                    font-size: 11px;
                    font-weight: data.quality-tier == QualityTier.best ? 700 : 400;
                    width: 45px;
                    horizontal-alignment: right;
                }
            }
            Text { text: data.mod-date; color: Themes.current.text-dim; font-size: 10px; }
        }
    }
}
